# Admin access (required for internal sheet entry UI at /admin)
# Only your team should know these values. Do not share publicly.
ADMIN_PASSWORD=choose-a-strong-password
ADMIN_SESSION_TOKEN=choose-a-long-random-token-for-cookie-session

# Google Sheets — choose ONE integration method below.

# Option A (recommended for quick setup): Google Apps Script webhook
# 1. Create a Google Sheet (tab: "VerihireAI Early Access")
# 2. Copy the Sheet ID from the URL: .../spreadsheets/d/SHEET_ID/edit
# 3. Paste scripts/google-apps-script.js into Apps Script
# 4. Set SPREADSHEET_ID at the top of that script to your Sheet ID
# 5. Deploy as Web App (Execute as: Me, Who has access: Anyone)
# 6. Copy the deployment URL here:
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbydR6gtNH7gAe5qJuyjwuEHomy7-QnRvatJQvIFp-Di_lsa1Q5b64XSFx_rllMFajeI/exec

# Option B: Google Service Account (direct Sheets API)
# 1. Create a Google Cloud project and enable Google Sheets API
# 2. Create a service account and download the JSON key
# 3. Share your Google Sheet with the service account email (Editor access)
# 4. Create a tab named "Pre-Registrations" in the sheet
# 5. Copy values from the JSON key:
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_TAB_NAME=VerihireAI Early Access
